MCU_SERIES = MIMXRT1052
MCU_VARIANT = MIMXRT1052DVL6B

JLINK_PATH ?= /media/RT1050-EVK/

MICROPY_FLOAT_IMPL = double
MICROPY_PY_LWIP = 1
MICROPY_PY_USSL = 1
