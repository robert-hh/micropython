CFLAGS += -DFSL_FEATURE_PHYKSZ8081_USE_RMII50M_MODE=1

SRC_ETH_C = \
	hal/phy/device/phyksz8081/fsl_phyksz8081.c \

deploy: $(BUILD)/firmware.bin
	cp $< $(JLINK_PATH)
